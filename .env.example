# Agent private key (hex, without 0x prefix)
AGENT_PRIVATE_KEY=

# Chain RPC URL (Base mainnet by default)
CHAIN_RPC_URL=https://mainnet.base.org

# Chain ID (Base = 8453)
CHAIN_ID=8453

# ERC-8004 Registry contract address
IDENTITY_REGISTRY_ADDRESS=

# Agent ID (ERC-8004 token ID)
AGENT_ID=

# Server port
PORT=3000

# Data directory for trust store, conversations, etc.
DATA_DIR=~/.trustedagents
