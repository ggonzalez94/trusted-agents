{
  "name": "trusted-agents-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:xmtp": "XMTP_INTEGRATION=true vitest run test/integration/xmtp-transport.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xmtp/node-sdk": "^5.4.0",
    "uuid": "^11.0.0",
    "viem": "2.46.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
