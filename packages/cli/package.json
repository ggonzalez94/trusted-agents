{
  "name": "trusted-agents-cli",
  "version": "0.2.0-beta.5",
  "type": "module",
  "main": "./dist/cli.js",
  "types": "./dist/cli.d.ts",
  "bin": {
    "tap": "./dist/bin.js"
  },
  "files": [
    "dist",
    "assets",
    "skills"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf assets/skills skills && mkdir -p assets/skills skills && cp -r ../../skills/trusted-agents assets/skills/trusted-agents && cp -r ../../skills/trusted-agents skills/trusted-agents && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@open-wallet-standard/core": "npm:@silicon-intern/ows-core@^1.2.0-eip712.3",
    "trusted-agents-sdk": "workspace:*",
    "@x402/evm": "^2.5.0",
    "@x402/fetch": "^2.5.0",
    "commander": "^13.0.0",
    "trusted-agents-core": "workspace:*",
    "viem": "2.46.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
